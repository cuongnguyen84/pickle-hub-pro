{
  "ci": {
    "collect": {
      "numberOfRuns": 2,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --headless=new"
      },
      "url": [
        "https://www.thepicklehub.net/",
        "https://www.thepicklehub.net/rankings",
        "https://www.thepicklehub.net/blog/what-is-dupr-pickleball-rating-system"
      ]
    },
    "assert": {
      "//": "Thresholds calibrated to the current prod baseline (2026-05-29): seo~0.66-0.69, CLS~0.11, perf~0.79, LCP~2.9s. They gate REGRESSIONS below today's state, not the pre-existing gap. NOTE: Lighthouse fetches with a browser UA so it scores the client-rendered SPA (pre-hydration meta), NOT the prerendered HTML Googlebot receives — the seo number is a measurement artifact, not Googlebot's view. Tighten as the site improves.",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.7 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.85 }],
        "categories:seo": ["error", { "minScore": 0.6 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 3500 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.15 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 600 }],
        "color-contrast": ["error", { "minScore": 1 }],
        "image-alt": ["error", { "minScore": 1 }],
        "document-title": ["error", { "minScore": 1 }],
        "html-has-lang": ["error", { "minScore": 1 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
