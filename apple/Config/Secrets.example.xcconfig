// Copy this file to `Secrets.xcconfig` and fill in the values.
// `Secrets.xcconfig` is git-ignored.
//
// The anon (publishable) key is designed to ship inside clients — it is
// gated by Row Level Security on the server. It is NOT a service-role key.

SUPABASE_PROJECT_REF = your_project_ref
SUPABASE_ANON_KEY = your_anon_publishable_key
